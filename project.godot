; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node2D",
"class": "Asteroid",
"language": "GDScript",
"path": "res://Entities/Asteriod/Asteriod.gd"
}, {
"base": "Node",
"class": "CargoComponent",
"language": "GDScript",
"path": "res://Entities/Components/Cargo.gd"
}, {
"base": "Resource",
"class": "DamageData",
"language": "GDScript",
"path": "res://Entities/Weapons/DamageData.gd"
}, {
"base": "KinematicBody2D",
"class": "Enemy",
"language": "GDScript",
"path": "res://Entities/Enemies/Enemy/Enemy.gd"
}, {
"base": "KinematicBody2D",
"class": "Miner",
"language": "GDScript",
"path": "res://Entities/Enemies/Miner/Miner.gd"
}, {
"base": "KinematicBody2D",
"class": "Player",
"language": "GDScript",
"path": "res://Entities/Player/Player.gd"
} ]
_global_script_class_icons={
"Asteroid": "",
"CargoComponent": "",
"DamageData": "",
"Enemy": "",
"Miner": "",
"Player": ""
}

[application]

config/name="Simple Shooting Game"
run/main_scene="res://Main.tscn"
config/icon="res://icon.png"

[autoload]

SignalBus="*res://SignalBus.gd"

[debug]

settings/stdout/print_fps=true

[display]

window/size/width=720
window/size/height=480
window/size/resizable=false
window/size/always_on_top=true
window/stretch/mode="2d"
window/stretch/aspect="keep"

[gui]

common/drop_mouse_on_gui_input_disabled=true

[input]

shoot={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":32,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}
left={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":65,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}
right={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":68,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}
move={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":87,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}
ui_debug_stop_enemies={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":16777244,"physical_scancode":0,"unicode":0,"echo":false,"script":null)
 ]
}

[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="projectiles"
2d_physics/layer_3="walls"
2d_physics/layer_4="enemy"
2d_physics/layer_5="playerProjectile"
2d_physics/layer_6="enemyProjectile"
2d_physics/layer_7="weaponRange"
2d_physics/layer_8="farm"

[physics]

common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_environment="res://default_env.tres"
